# URL del servidor signaling (sin /ws al final, se agrega automáticamente)
# Producción (Render):
SIGNALING_URL=wss://dps-desk.onrender.com
# Desarrollo local:
# SIGNALING_URL=ws://localhost:4000

# URL HTTP del backend (para fetch de ICE servers y registro de device)
# Producción (Render):
BACKEND_HTTP_URL=https://dps-desk.onrender.com
# Desarrollo local:
# BACKEND_HTTP_URL=http://localhost:4000

# (Opcional) ID fijo del POS — si está, sobrescribe el UUID generado
# Útil para POS conocidos que existen en la BD/mockData del backend
# POS_ID=isabel-riquelme-pos-real
