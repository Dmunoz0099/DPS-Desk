PORT=4000
JWT_SECRET=dpsdesk_super_secret_change_me

# Supabase — requerido para que el backend lea/escriba en la BD
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# CORS — opcional. Si no se setea, permite todos los orígenes (el backend
# usa Bearer tokens, no cookies, así que CORS abierto es seguro).
# Si quieres restringir: CORS_ORIGIN=https://tu-frontend.com,http://localhost:8080
# CORS_ORIGIN=*

# Keep-alive para Render free tier — Render expone RENDER_EXTERNAL_URL
# automáticamente, no es necesario setearlo. Solo defínelo aquí si corres
# en otro host y quieres self-ping.
# SELF_URL=https://dps-desk.onrender.com

# (Opcional) STUN/TURN — para WebRTC fuera de red local
# TURN_SECRET=CHANGE_THIS_STRONG_SECRET_32CHARS
# TURN_HOST=ip.o.dominio.del.vps
# TURN_PORT=3478
