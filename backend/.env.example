PORT=4000
JWT_SECRET=dpsdesk_super_secret_change_me

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# CORS — coma-separados o "*" para permitir todo (Bearer auth, sin cookies).
# Ej: CORS_ORIGIN=dpsdesk://app,http://localhost:5173,http://localhost:8080
CORS_ORIGIN=*

# TURN (opcional, para WebRTC fuera de red local)
TURN_SECRET=CHANGE_THIS_STRONG_SECRET_32CHARS
TURN_HOST=ip.o.dominio.del.vps
TURN_PORT=3478

BACKEND_HTTP_URL=http://localhost:4000
